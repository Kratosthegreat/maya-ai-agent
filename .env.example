# Maya Secretary Bot - Environment Variables
# Copy this file to .env and fill in your actual values

# === REQUIRED: TELEGRAM BOT ===
# Get this from @BotFather on Telegram
TELEGRAM_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ_EXAMPLE

# === REQUIRED: AI SERVICE ===
# Get this from Google AI Studio: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyA_EXAMPLE_KEY_GET_FROM_GOOGLE_AI_STUDIO

# === REQUIRED: WEBHOOK (for production) ===
# Your Render app URL + /webhook
WEBHOOK_URL=https://your-app-name.onrender.com/webhook

# === REQUIRED: SECURITY KEYS ===
# Generate these with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-32-chars-minimum
ENCRYPTION_KEY=your-encryption-key-here-32-chars-minimum

# === DATABASE ===
# Render provides this automatically for PostgreSQL
# For local development, you can use SQLite:
DATABASE_URL=sqlite:///maya.db
# For production PostgreSQL (Render will provide this):
# DATABASE_URL=postgresql://user:password@host:port/database

# === APPLICATION SETTINGS ===
# Environment: development, staging, production
ENVIRONMENT=production

# Debug mode: true for development, false for production
DEBUG=false

# Port (Render sets this automatically)
PORT=5000

# === AI CONFIGURATION ===
# AI model to use
GEMINI_MODEL=gemini-1.5-flash

# Maximum conversation history to keep
MAX_HISTORY_MESSAGES=20

# === RATE LIMITING ===
# Maximum requests per user per minute
MAX_REQUESTS_PER_MINUTE=30

# === EXTERNAL SERVICES (Optional) ===
# OpenWeatherMap API key (for enhanced weather features)
WEATHER_API_KEY=your-openweathermap-api-key-optional

# Google Calendar credentials (for future calendar integration)
GOOGLE_CALENDAR_CREDENTIALS=

# Gmail credentials (for future email integration)
GMAIL_CREDENTIALS=

# === DATABASE TUNING (Optional) ===
# Database connection pool size
DB_POOL_SIZE=5

# Database connection pool overflow
DB_MAX_OVERFLOW=10

# Enable SQL query logging (for debugging)
DATABASE_ECHO=false

# === LOGGING (Optional) ===
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable file logging
LOG_TO_FILE=false

# Log file path
LOG_FILE_PATH=maya_bot.log

# === FEATURE FLAGS (Optional) ===
# Enable advanced AI features
ENABLE_ADVANCED_AI=true

# Enable conversation analytics
ENABLE_ANALYTICS=false

# Enable user feedback system
ENABLE_FEEDBACK=false

# === WEBHOOK CONFIGURATION (Advanced) ===
# Webhook timeout in seconds
WEBHOOK_TIMEOUT=10

# Maximum webhook retries
WEBHOOK_MAX_RETRIES=3

# === TELEGRAM SPECIFIC (Advanced) ===
# Telegram API timeout
TELEGRAM_TIMEOUT=10

# Maximum message length
MAX_MESSAGE_LENGTH=4096

# Parse mode for messages (HTML, Markdown, or empty)
DEFAULT_PARSE_MODE=

# === DEVELOPMENT ONLY ===
# Use ngrok for local development webhook
NGROK_TUNNEL_URL=

# Enable development mode features
DEV_MODE=false

# Skip webhook setup (for local development)
SKIP_WEBHOOK_SETUP=false
